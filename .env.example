# =============================================================================
# AMLIC Project Environment Variables
# Copy this to .env and fill in your values.
# =============================================================================

# HuggingFace token — needs gated access to meta-llama/Llama-3.2-3B-Instruct
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to serve (do not change unless both GPUs are confirmed ≥24 GB)
MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct

# ---------------------------------------------------------------------------
# VM Tailscale IPs (filled in after Phase 1)
# ---------------------------------------------------------------------------
# Prefill VM — L4 (24 GB) — handles prompt prefill + KV cache production
VM_PREFILL_IP=100.x.x.x
VM_PREFILL_SSH_KEY=~/.ssh/gcp_prefill_key

# Decode VM — T4 (16 GB) — handles autoregressive decoding + KV cache consumption
VM_DECODE_IP=100.x.x.x
VM_DECODE_SSH_KEY=~/.ssh/gcp_decode_key

# Collocated baseline runs on the L4 (prefill VM)
VM_COLOCATED_IP=${VM_PREFILL_IP}

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
COLLOCATED_PORT=8000
PREFILL_PORT=8100
DECODE_PORT=8200
PROXY_PORT=9000
NIXL_SIDE_CHANNEL_PORT=5600

# ---------------------------------------------------------------------------
# Router config
# ---------------------------------------------------------------------------
# Threshold N (tokens) — updated by analysis/compute_threshold.py
ROUTING_THRESHOLD=500

# Endpoint URLs (derived from above — override if needed)
COLLOCATED_URL=http://${VM_COLOCATED_IP}:${COLLOCATED_PORT}/v1
DISAGG_PROXY_URL=http://${VM_PREFILL_IP}:${PROXY_PORT}/v1

# ---------------------------------------------------------------------------
# GCP cost rates ($/hr, on-demand, us-central1, as of 2025-Q1 — verify!)
# ---------------------------------------------------------------------------
GCP_L4_COST_PER_HOUR=0.71
GCP_T4_COST_PER_HOUR=0.35

# ---------------------------------------------------------------------------
# SSH user on both VMs (usually your GCP username)
# ---------------------------------------------------------------------------
SSH_USER=your_gcp_username
